project_name        = "autoforge"
aws_region          = "ap-south-1"
cluster_name        = "autoforge-eks"
node_instance_types = ["t3.micro"]
node_desired_size   = 1
node_min_size       = 1
node_max_size       = 2

# Set this to your GitHub "username/repo-name" to allow GitHub Actions to
# assume an AWS IAM role via OIDC (no long-lived access keys in CI/CD).
github_oidc_repo    = "your-github-username/automobile-app-eks-kubernetes-deployment"

# --- RDS MySQL ---
db_name           = "autoforge"
db_username       = "autoforge_admin"
db_password       = "ChangeThisToAStrongPassword123!"   # do NOT commit a real password - this file is gitignored
db_instance_class = "db.t3.micro"
